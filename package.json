{
  "name": "musicsync",
  "version": "0.3.1",
  "description": "iTunesのmusicフォルダをイイ感じに同期する",
  "author": "hi2ma-bu4",
  "keywords": [],
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "check-types": "npx tsc --noEmit",
    "build:main": "node dev/build.mjs",
    "build:renderer": "vite build --config vite.config.mjs",
    "build": "npm run check-types && npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "dev": "vite --config vite.config.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "electron": "^43.1.1",
    "electron-store": "^11.0.2",
    "lucide-static": "^1.25.0",
    "music-metadata": "^11.14.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@chialab/esbuild-plugin-commonjs": "^0.19.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "allowScripts": {
    "esbuild": true
  },
  "volta": {
    "node": "24.18.0",
    "npm": "12.0.1"
  }
}
